rules_version = '2';

/**
 * Firestore Security Rules
 * Smart Inventory Management System
 *
 * @author Nicolas Boggioni Troncoso
 * @course BSc Computer Science - Final Year Project
 * @institution Dorset College Dublin
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
             request.auth.token.email in ['admin@inventory.com', 'admin@wishbone.com'];
    }

    // Helper function to check if user is manager or admin
    function isManagerOrAdmin() {
      return isAuthenticated() &&
             request.auth.token.email in [
               'admin@inventory.com',
               'admin@wishbone.com',
               'manager@inventory.com',
               'manager@wishbone.com'
             ];
    }

    // Inventory collection - all authenticated users can read and update stock
    match /inventory/{itemId} {
      // Anyone authenticated can read
      allow read: if isAuthenticated();

      // Anyone authenticated can update (stock changes)
      allow update: if isAuthenticated();

      // Only managers and admins can create/delete
      allow create, delete: if isManagerOrAdmin();
    }

    // POS Configuration - managers and admins only
    match /posConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isManagerOrAdmin();
    }

    // Recipes collection - all authenticated users can read, managers/admins can write
    match /recipes/{recipeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManagerOrAdmin();
    }

    // Mobile App Authorizations: all authenticated users can read, managers/admins can write
    match /recipes/{recipeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isManagerOrAdmin();
    }
    
    match /tables/{tableId} {
      allow read: if isAuthenticated()
      allow create, update, delete: if isManagerOrAdmin();
    }
    
    match /menuItems/{menuItemId} {
      allow read: if isAuthenticated()
      allow create, update, delete: if isManagerOrAdmin();
    }

    match /orders/{orderId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isManagerOrAdmin();

    // Order items subcollection
    match /items/{itemId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isManagerOrAdmin();
    }
    }

    // Order sequence counter — authenticated users read/update, managers create
    match /counters/{counterId} {
      allow read, update: if isAuthenticated();
      allow create: if isManagerOrAdmin();
    }

    // User settings (future use)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
